# =========================================================================
# TERRAFORM ENVIRONMENT VARIABLES (.env)
# =========================================================================
# ⚠️ Rename this file to .env (not .env.example) and DO NOT commit .env 
# to GitHub. It is already added to .gitignore.
# =========================================================================

# 1. AWS Credentials
# Set these ONLY if you are not using `aws configure` locally. 
# Terraform uses these keys to authenticate with AWS.
# AWS_ACCESS_KEY_ID="your_aws_access_key"
# AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_DEFAULT_REGION="us-east-1"

# 2. Terraform Variables
# Any variable defined in variables.tf can be populated here by adding the 
# TF_VAR_ prefix. This is the safest way to pass passwords.
TF_VAR_db_password="ProdStrongPassword!@#12"

# Example: If you wanted to override the RDS username (defined in variables.tf)
# TF_VAR_db_username="myadmin"

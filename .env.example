# ========================================================================
# .ENV.EXAMPLE - ENVIRONMENT VARIABLES TEMPLATE
# ========================================================================
#
# Copy this file to .env and update with your values
# cp .env.example .env
#
# NEVER commit .env file to git!
# It contains secrets!
#
# ========================================================================

# ========================================================================
# DJANGO SETTINGS
# ========================================================================

# Debug mode (False for production!)
DEBUG=False

# Secret key for Django (generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
SECRET_KEY=django-insecure-your-super-secret-key-here-change-this

# Allowed hosts (comma separated)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Environment (development, staging, production)
ENVIRONMENT=development

# ========================================================================
# DATABASE CONFIGURATION
# ========================================================================

# PostgreSQL connection
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://stockuser:stockpass123@localhost:5432/stockdb

# Database name
DB_NAME=stockdb

# Database user
DB_USER=stockuser

# Database password
DB_PASSWORD=stockpass123

# Database host
DB_HOST=localhost

# Database port
DB_PORT=5432

# ========================================================================
# REDIS / CACHE CONFIGURATION
# ========================================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Cache timeout (seconds)
CACHE_TIMEOUT=300

# ========================================================================
# JWT / AUTHENTICATION
# ========================================================================

# JWT secret key
JWT_SECRET_KEY=your-jwt-secret-key-here

# JWT token expiration (seconds)
JWT_EXPIRATION_HOURS=24

# Refresh token expiration
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ========================================================================
# ML MODEL CONFIGURATION
# ========================================================================

# Path to ML model
ML_MODEL_PATH=/app/resources/stock_prediction_model.keras

# Model prediction timeout (seconds)
ML_PREDICTION_TIMEOUT=30

# Max prediction days
ML_MAX_PREDICTION_DAYS=365

# Min prediction days
ML_MIN_PREDICTION_DAYS=1

# ========================================================================
# API CONFIGURATION
# ========================================================================

# API version
API_VERSION=v1

# API rate limiting
RATE_LIMIT_ENABLED=True

# Rate limit: requests per minute
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ========================================================================
# FRONTEND CONFIGURATION
# ========================================================================

# Backend API base URL (for frontend)
VITE_BACKEND_BASE_API=http://localhost:8000/api/v1/

# Backend root URL
VITE_BACKEND_ROOT=http://localhost:8000

# Frontend port
FRONTEND_PORT=3000

# ========================================================================
# SECURITY CONFIGURATION
# ========================================================================

# CORS allowed origins (comma separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# CSRF trusted origins
CSRF_TRUSTED_ORIGINS=localhost,127.0.0.1

# Security headers
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ========================================================================
# LOGGING CONFIGURATION
# ========================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=/app/logs/app.log

# Max log file size (bytes)
LOG_FILE_MAX_BYTES=10485760  # 10 MB

# Number of backup log files
LOG_BACKUP_COUNT=5

# ========================================================================
# EMAIL CONFIGURATION (Optional)
# ========================================================================

# Email backend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Email host
EMAIL_HOST=smtp.gmail.com

# Email port
EMAIL_PORT=587

# Email TLS
EMAIL_USE_TLS=True

# Email username
EMAIL_HOST_USER=your-email@gmail.com

# Email password / app password
EMAIL_HOST_PASSWORD=your-email-password

# From email
DEFAULT_FROM_EMAIL=noreply@stockprediction.com

# ========================================================================
# AWS CONFIGURATION (Optional - For Day 4+)
# ========================================================================

# AWS region
AWS_REGION=us-east-1

# AWS access key
AWS_ACCESS_KEY_ID=your-aws-access-key

# AWS secret key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# S3 bucket for models
AWS_S3_BUCKET_NAME=stock-prediction-models

# ========================================================================
# MONITORING & OBSERVABILITY (Optional)
# ========================================================================

# Sentry DSN (error tracking)
SENTRY_DSN=

# NewRelic key
NEW_RELIC_LICENSE_KEY=

# ========================================================================
# DOCKER CONFIGURATION
# ========================================================================

# Docker compose project name
COMPOSE_PROJECT_NAME=stock_prediction

# Container environment
CONTAINER_ENV=docker

# ========================================================================
# DEVELOPMENT ONLY
# ========================================================================

# Enable API documentation
API_DOCUMENTATION_ENABLED=True

# Enable Django admin
DJANGO_ADMIN_ENABLED=True

# Allowed file uploads (MB)
MAX_FILE_UPLOAD_MB=10

# ========================================================================
# HOW TO USE THIS FILE
# ========================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env with your values:
#    nano .env  (or your editor)
#
# 3. For Docker:
#    docker-compose loads .env automatically
#
# 4. For Django:
#    from decouple import config
#    secret_key = config('SECRET_KEY')
#
# ========================================================================
